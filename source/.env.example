VITE_APP_NAME="${APP_NAME}"
LOG_VIEWER_ENABLED=true

# Passcode time to live in minutes
PASSCODE_TTL_MINUTES_FOR_REGISTRATION=10
PASSCODE_TTL_MINUTES_FOR_RESET=30
